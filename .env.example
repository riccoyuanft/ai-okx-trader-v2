# ============================================================
# Platform Secrets
# Generate FERNET_KEY: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Generate JWT_SECRET: python -c "import secrets; print(secrets.token_hex(32))"
# ============================================================
FERNET_KEY=your-fernet-key-here
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRE_HOURS=24

# ============================================================
# Supabase (https://app.supabase.com)
# ============================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# ============================================================
# Redis (docker internal network)
# ============================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ============================================================
# App
# ============================================================
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# ============================================================
# AI Providers (System-wide, users select provider only)
# ============================================================
# OpenAI (default)
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# Qwen (通义千问)
QWEN_API_KEY=your-qwen-api-key
QWEN_MODEL=qwen-plus
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Doubao (豆包)
DOUBAO_API_KEY=your-doubao-api-key
DOUBAO_MODEL=doubao-pro-32k
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
